{
  "name": "robot-admin-monorepo",
  "version": "2.2.0",
  "private": true,
  "description": "Robot Admin Monorepo - 基于 Bun Workspaces 的企业级多应用管理平台",
  "author": {
    "name": "ChenY",
    "email": "ycyplus@gmail.com",
    "url": "https://github.com/ChenyCHENYU"
  },
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter @robot-admin/internal dev",
    "dev:internal": "bun --filter @robot-admin/internal dev",
    "dev:saas": "bun --filter @robot-admin/saas dev",
    "build": "bun run build:apps",
    "build:apps": "bun --filter './apps/*' build",
    "build:internal": "bun --filter @robot-admin/internal build",
    "build:saas": "bun --filter @robot-admin/saas build",
    "preview:internal": "bun --filter @robot-admin/internal preview",
    "preview:saas": "bun --filter @robot-admin/saas preview",
    "lint": "eslint packages/ && bun --filter './apps/*' lint",
    "lint:apps": "bun --filter './apps/*' lint",
    "lint:packages": "eslint packages/",
    "format": "prettier --write .",
    "type-check": "bun --filter './apps/*' type-build",
    "clean": "rm -rf apps/*/dist apps/*/node_modules/.tmp",
    "clean:modules": "rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "fresh": "bun run clean:modules && bun install",
    "prepare": "husky",
    "commit": "bunx cz",
    "cz": "git-cz"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,mts,vue}": [
      "oxlint --max-warnings 0 --deny-warnings",
      "eslint --fix --no-cache",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@robot-admin/git-standards": "latest",
    "@robot-admin/shared-config": "workspace:*",
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "commitizen": "^4.3.1",
    "cz-customizable": "^7.5.1",
    "eslint": "^10.0.3",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-oxlint": "^1.51.0",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "oxlint": "^1.52.0",
    "prettier": "^3.8.1",
    "typescript": "~5.8.3"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    }
  },
  "packageManager": "bun@1.3.10",
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=22.0.0"
  }
}
