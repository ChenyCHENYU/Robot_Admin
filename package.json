{
  "name": "robot-admin-monorepo",
  "version": "2.2.0",
  "private": true,
  "description": "Robot Admin Monorepo - 基于 Bun Workspaces 的企业级多应用管理平台",
  "author": {
    "name": "ChenY",
    "email": "ycyplus@gmail.com",
    "url": "https://github.com/ChenyCHENYU"
  },
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter @robot-admin/internal dev",
    "dev:internal": "bun --filter @robot-admin/internal dev",
    "dev:saas": "bun --filter @robot-admin/saas dev",
    "build": "bun run build:apps",
    "build:apps": "bun --filter './apps/*' build",
    "build:internal": "bun --filter @robot-admin/internal build",
    "build:saas": "bun --filter @robot-admin/saas build",
    "preview:internal": "bun --filter @robot-admin/internal preview",
    "preview:saas": "bun --filter @robot-admin/saas preview",
    "lint": "bun --filter './apps/*' lint",
    "format": "bun --filter './apps/*' format",
    "type-check": "bun --filter './apps/*' type-build",
    "clean": "rm -rf apps/*/dist apps/*/node_modules/.tmp",
    "clean:modules": "rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "fresh": "bun run clean:modules && bun install",
    "prepare": "husky",
    "commit": "bunx cz",
    "cz": "git-cz"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@robot-admin/git-standards": "latest",
    "@types/node": "^22.19.15",
    "commitizen": "^4.3.1",
    "cz-customizable": "^7.5.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "typescript": "~5.8.3"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    }
  },
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=22.0.0"
  }
}