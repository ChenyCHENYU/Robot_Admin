{
  // Robot Admin Monorepo — 应用级 TypeScript 基础配置
  // 各 app 的 tsconfig.app.json 继承此文件，仅需补充 include/exclude/paths 等差异项
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    // ==================== 编译输出 ====================
    "declaration": true,
    "emitDeclarationOnly": true,

    // ==================== 增量编译 ====================
    "composite": true,
    "incremental": true,

    // ==================== 模块解析 ====================
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    // ==================== Vue / JSX ====================
    "jsx": "preserve",
    "jsxImportSource": "vue",

    // ==================== 类型检查 ====================
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,

    // ==================== 性能 ====================
    "skipLibCheck": true
  }
}
