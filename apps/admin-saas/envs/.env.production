#* 生产环境

# 应用标题
VITE_APP_TITLE = ROBOT ADMIN | SAAS

# Environmental variable
VITE_APP_ENV = production

# # Interface request address
VITE_API_BASE = https://apifoxmock.com/m1/4902805-4559325-default

# ========== i18n 翻译配置 ==========
# 生产构建无需 i18n 插件（运行时由 lang/index.js 提供 $t，插件只在开发时扫描/翻译）
VITE_I18N_ENABLED=false

# 生产环境不需要真实 API 密钥（buildToDist 只需要插件启用即可）
VITE_YOUDAO_APP_ID=dummy
VITE_YOUDAO_APP_KEY=dummy
