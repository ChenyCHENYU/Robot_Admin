{
  "name": "@robot-admin/saas",
  "version": "1.0.0",
  "private": true,
  "description": "Robot Admin SaaS 版本 - 多租户中后台管理系统（轻量版）",
  "author": {
    "name": "ChenY",
    "email": "ycyplus@gmail.com",
    "url": "https://github.com/ChenyCHENYU"
  },
  "license": "MIT",
  "scripts": {
    "dev": "NODE_NO_WARNINGS=1 env-manager dev && vite",
    "dev:local": "USE_LOCAL_PACKAGES=true bun run dev",
    "dev:components": "USE_LOCAL_COMPONENTS=true bun run dev",
    "dev:devtools": "VITE_DEVTOOLS=true bun run dev",
    "build": "env-manager prod && vite build",
    "build:test": "env-manager test && vite build --mode test --emptyOutDir",
    "build:staging": "env-manager staging && vite build --mode staging --profile",
    "preview": "bun run build && vite preview",
    "type-watch": "vue-tsc --noEmit --watch",
    "type-build": "vue-tsc --build tsconfig/tsconfig.app.json --force",
    "build:check": "bun run type-build && bun run build",
    "lint": "oxlint . --fix -D correctness --ignore-path .gitignore && eslint . --fix",
    "format": "prettier --write src/",
    "check-branch": "gbd",
    "check-types": "ts-type-cleaner analyze",
    "gen:route-i18n": "bun run scripts/generate-route-translations.ts",
    "analyze": "vite build --mode analyze"
  },
  "dependencies": {
    "@antv/x6": "^2.19.2",
    "@iconify-json/ri": "^1.2.10",
    "@iconify/vue": "^5.0.0",
    "@kangc/v-md-editor": "^2.3.18",
    "@robot-admin/directives": "latest",
    "@robot-admin/file-utils": "latest",
    "@robot-admin/form-validate": "latest",
    "@robot-admin/layout": "latest",
    "@robot-admin/naive-ui-components": "^0.6.31",
    "@robot-admin/request-core": "latest",
    "@robot-admin/theme": "latest",
    "@splinetool/runtime": "^1.12.68",
    "@vercel/analytics": "^1.6.1",
    "@visactor/vtable-gantt": "^1.23.3",
    "@vue-flow/core": "^1.41.8",
    "@vueuse/core": "^13.9.0",
    "axios": "^1.13.6",
    "echarts": "^6.0.0",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "motion-v": "^1.10.3",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "print-js": "^1.6.0",
    "robot-admin-env-manager": "^1.0.5",
    "rolldown": "1.0.0-rc.12",
    "seemly": "^0.3.8",
    "vite-plugin-preloader": "^1.1.3",
    "vue": "^3.5.30",
    "vue-command-palette": "^0.2.3",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@iconify-json/carbon": "^1.2.19",
    "@iconify-json/ic": "^1.2.4",
    "@iconify-json/la": "^1.2.1",
    "@iconify-json/mdi": "^1.2.3",
    "@inspira-ui/plugins": "^0.0.1",
    "@robot-admin/shared-config": "workspace:*",
    "@tsconfig/node22": "^22.0.5",
    "@types/nprogress": "^0.2.3",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/runtime-core": "^3.5.30",
    "@vue/tsconfig": "^0.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "git-branch-check-diff-commits": "^1.2.2",
    "jiti": "^2.6.1",
    "naive-ui": "^2.44.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.97.3",
    "ts-type-cleaner": "^5.0.8",
    "unocss": "^66.6.6",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^31.0.0",
    "vite": "8.0.3",
    "vite-auto-i18n-plugin": "^1.1.16",
    "vite-console-plugin": "^2.0.15",
    "vite-plugin-vue-devtools": "^7.7.9",
    "vue-tsc": "^3.2.6"
  }
}
